# Africa's Talking credentials
# Get these from https://africastalking.com/
AT_USERNAME=sandbox
AT_API_KEY=your_api_key_here

# Optional: SMS sender ID (alphanumeric, e.g. "RANGERNET")
# Leave blank in sandbox mode
AT_SENDER_ID=

# Comma-separated ranger phone numbers to receive SMS alerts
RANGER_NUMBERS=+2348000000000,+2348111111111

# Server port
PORT=4000
